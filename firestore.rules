rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isActiveUser() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    match /system/config {
      allow read: if isAuth();
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin() && isActiveUser();
      allow update: if isAuth() && isActiveUser() && (
        (request.auth.uid == userId) ||
        (isAdmin() && resource.data.role != 'owner') ||
        isOwner()
      );
      allow delete: if isOwner() && resource.data.role != 'owner';
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth() && isActiveUser();
      allow update, delete: if false;
    }

    match /desktopLayouts/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
